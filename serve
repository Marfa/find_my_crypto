class EvmRpcProxy < WEBrick::HTTPServlet::AbstractServlet
  CHAINS = {
    'bsc' => URI('https://bsc.publicnode.com'),
    'avax' => URI('https://avalanche-c-chain.publicnode.com'),
  }.freeze

  def do_OPTIONS(req, res)
    cors!(req, res)
    res['Access-Control-Allow-Methods'] = 'POST, OPTIONS'
    res['Access-Control-Allow-Headers'] = 'Content-Type'
    res.status = 204
  end

  def do_POST(req, res)
    cors!(req, res)
    res['Content-Type'] = 'application/json'
    chain = req.query['chain']
    chain = chain.first if chain.is_a?(Array)
    chain = chain.to_s
    if chain.empty?
      qs = URI(req.request_uri).query.to_s
      chain = CGI.parse(qs)['chain']&.first.to_s
    end
    uri = CHAINS[chain]
    unless uri
      res.status = 400
      res.body = JSON.generate(error: 'unknown_chain')
      return
    end
    forward_post(uri, req.body, res)
  rescue StandardError => e
    res.status = 503
    res.body = JSON.generate(jsonrpc: '2.0', error: { code: -32000, message: e.message }, id: nil)
  end
end

def forward_get(uri, res, accept: nil)
  http = Net::HTTP.new(uri.host, uri.port)
  http.use_ssl = true
  http.read_timeout = 22
  http.open_timeout = 6
  req = Net::HTTP::Get.new(uri)
  req['Accept'] = accept if accept
  req['Accept-Encoding'] = 'identity'
  reply = http.request(req)
  res.status = reply.code.to_i
  res['Content-Type'] = reply['Content-Type'] || 'application/json'
  res.body = reply.body
end

def forward_post(uri, body, res)
  http = Net::HTTP.new(uri.host, uri.port)
  http.use_ssl = true
  http.read_timeout = 22
  http.open_timeout = 6
  req = Net::HTTP::Post.new(uri)
  req['Content-Type'] = 'application/json'
  req['Accept-Encoding'] = 'identity'
  req.body = body
  reply = http.request(req)
  res.status = reply.code.to_i
  res['Content-Type'] = reply['Content-Type'] || 'application/json'
  res.body = reply.body
end

