  DocumentRoot: root,
  BindAddress: bind,
)
server.mount '/api/solana-rpc', SolanaRpcProxy
server.mount '/api/solana-stake', SolanaStakeServlet
server.mount '/api/koios', KoiosProxy
server.mount '/api/cosmos', CosmosProxy
server.mount '/api/polkadot-rpc', PolkadotRpcProxy
server.mount '/api/polkadot', PolkadotProxy
server.mount '/api/near-rpc', NearRpcProxy
server.mount '/api/coingecko', CoinGeckoProxy
server.mount '/api/evm-rpc', EvmRpcProxy

trap('INT') { server.shutdown }
puts "Find My Crypto → http://127.0.0.1:#{port}/"
server.start
